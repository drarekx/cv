---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Assessorament tecnològic per a pimes — Gerard Fortea, consultor web freelance';
const pageDescription = 'Serveis d\'assessorament tecnològic i desenvolupament d\'aplicacions web a mida per a pimes. Més de 15 anys d\'experiència com a programador web fullstack freelance a Catalunya.';

const services = [
  {
    title: "Desenvolupament web a mida",
    description: "Disseny i programació d'aplicacions web adaptades al vostre negoci: des de panells de gestió interna fins a plataformes orientades al client, amb tecnologies modernes i escalables.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/>`,
  },
  {
    title: "Assessorament tecnològic",
    description: "Anàlisi de les vostres necessitats digitals i orientació en la tria de les solucions més adequades: tecnologies, eines, arquitectura de sistemes i proveïdors de serveis cloud.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>`,
  },
  {
    title: "Manteniment i evolució de projectes",
    description: "Suport tècnic continuat per a webs i aplicacions existents: correcció d'errors, implementació de noves funcionalitats i migració o modernització de tecnologies obsoletes.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.653-4.655m5.8-2.079 1.323-1.612a4.5 4.5 0 0 0-6.364-6.364L8.198 6.168"/>`,
  },
  {
    title: "Digitalització de processos",
    description: "Identificació i automatització de fluxos de treball manuals mitjançant solucions digitals a mida, millorant l'eficiència operativa i reduint errors a la vostra pime.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5"/>`,
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "name": "Gerard Fortea Castellsague",
      "jobTitle": "Desenvolupador web Fullstack — Consultor tecnològic freelance",
      "url": "https://gerard-fortea.dev",
      "email": "fortea.gerard@mail.com",
      "telephone": "+34616271011",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Maià de Montcal",
        "addressRegion": "Girona",
        "addressCountry": "ES"
      },
      "sameAs": [
        "https://www.linkedin.com/in/gerard-fortea-a3863741/",
        "https://github.com/drarekx"
      ]
    },
    {
      "@type": "Service",
      "name": "Assessorament tecnològic i desenvolupament web per a pimes",
      "description": pageDescription,
      "provider": {
        "@type": "Person",
        "name": "Gerard Fortea Castellsague"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Catalunya"
      },
      "serviceType": [
        "Desenvolupament d'aplicacions web a mida",
        "Assessorament tecnològic",
        "Manteniment i evolució de projectes web",
        "Digitalització de processos"
      ]
    }
  ]
};
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <div class="min-h-screen py-8 px-4 md:py-14">
    <div class="max-w-5xl mx-auto shadow-2xl">

      <!-- ACCENT LINE -->
      <div class="h-[3px] bg-blue-600"></div>

      <!-- HEADER -->
      <header class="relative bg-slate-900 dark:bg-slate-950 text-white px-8 py-10 md:px-12">

        <!-- Theme toggle -->
        <button id="theme-toggle" aria-label="Canviar tema"
          class="absolute top-5 right-5 p-2 text-slate-500 hover:text-slate-200 transition-colors">
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-5.4-5.4c0-1.81.89-3.42 2.26-4.4A9.14 9.14 0 0 0 12 3z"/>
          </svg>
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 hidden">
            <path d="M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7zM2 13h2a1 1 0 0 0 0-2H2a1 1 0 0 0 0 2zm18 0h2a1 1 0 0 0 0-2h-2a1 1 0 0 0 0 2zM11 2v2a1 1 0 0 0 2 0V2a1 1 0 0 0-2 0zm0 18v2a1 1 0 0 0 2 0v-2a1 1 0 0 0-2 0zM5.99 4.58a1 1 0 0 0-1.41 1.41l1.06 1.06a1 1 0 0 0 1.41-1.41L5.99 4.58zm12.37 12.37a1 1 0 0 0-1.41 1.41l1.06 1.06a1 1 0 0 0 1.41-1.41l-1.06-1.06zm1.06-10.96a1 1 0 0 0-1.41-1.41l-1.06 1.06a1 1 0 0 0 1.41 1.41l1.06-1.06zM7.05 18.36a1 1 0 0 0-1.41-1.41l-1.06 1.06a1 1 0 0 0 1.41 1.41l1.06-1.06z"/>
          </svg>
        </button>

        <div class="flex flex-col sm:flex-row items-start gap-7">
          <img
            src="https://media.licdn.com/dms/image/v2/D4D03AQGqT-t39MPcGA/profile-displayphoto-shrink_400_400/profile-displayphoto-shrink_400_400/0/1695049957282?e=1733356800&v=beta&t=vJ0P33zO51tNL4Up2is14Z9dI_eRWYThRSXXtCJEsTU"
            alt="Gerard Fortea"
            class="w-[88px] h-[88px] object-cover shrink-0 border border-slate-700"
          />
          <div>
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight">Gerard Fortea Castellsague</h1>
            <p class="mt-1.5 text-blue-400 font-medium text-base">Desenvolupador web Fullstack</p>
            <p class="mt-3 text-slate-400 text-sm leading-relaxed max-w-2xl">
              Programador amb més de 15 anys d'experiència en el desenvolupament web. Em caracteritzo per ser creatiu,
              resolutiu i altament responsable. Mantinc un enfocament constant en l'adquisició de noves habilitats i
              l'aprenentatge de les últimes tecnologies del sector.
            </p>
          </div>
        </div>
      </header>

      <!-- NAV TABS -->
      <nav class="bg-slate-800 dark:bg-slate-900 border-b border-slate-700 dark:border-slate-800 px-6 flex gap-1">
        <a href="/"
          class="px-4 py-3 text-sm font-medium text-slate-400 border-b-2 border-transparent hover:text-slate-200 transition-colors">
          CV
        </a>
        <a href="/serveis"
          class="px-4 py-3 text-sm font-medium text-white border-b-2 border-blue-500 -mb-px transition-colors">
          Serveis
        </a>
      </nav>

      <!-- MAIN CONTENT -->
      <main class="bg-white dark:bg-slate-900 px-8 py-10 md:px-10">

        <!-- Intro -->
        <section class="mb-10" aria-labelledby="serveis-titol">
          <h2 id="serveis-titol" class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400 dark:text-slate-500 mb-5 pb-2 border-b border-slate-200 dark:border-slate-700">
            Consultor tecnològic freelance · Pimes a Catalunya
          </h2>
          <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed max-w-2xl">
            Soc <strong class="text-slate-800 dark:text-slate-200 font-semibold">Gerard Fortea</strong>,
            programador web freelance amb més de 15 anys d'experiència. Ofereixo serveis
            d'<strong class="text-slate-800 dark:text-slate-200 font-semibold">assessorament tecnològic i desenvolupament d'aplicacions web a mida</strong>
            per a petites i mitjanes empreses (pimes) a Catalunya que volen digitalitzar processos,
            millorar la seva presència digital o necessiten un referent tecnològic extern de confiança.
          </p>
        </section>

        <!-- Service cards grid -->
        <section class="mb-10" aria-label="Serveis oferts">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {services.map(({ title, description, icon }) => (
            <article class="group border border-slate-200 dark:border-slate-700 p-5 hover:border-blue-500 dark:hover:border-blue-500 transition-colors duration-200 cursor-pointer">
              <div class="flex items-start gap-4">
                <div class="shrink-0 w-9 h-9 flex items-center justify-center bg-blue-50 dark:bg-blue-950 text-blue-600 dark:text-blue-400 group-hover:bg-blue-600 group-hover:text-white dark:group-hover:bg-blue-600 dark:group-hover:text-white transition-colors duration-200">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5" set:html={icon} />
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-slate-100 text-sm mb-1.5">{title}</h3>
                  <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">{description}</p>
                </div>
              </div>
            </article>
          ))}
          </div>
        </section>

        <!-- CTA -->
        <div class="bg-slate-900 dark:bg-slate-950 px-7 py-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5">
          <div>
            <p class="text-white font-semibold text-sm mb-0.5">Parlem del vostre projecte</p>
            <p class="text-slate-400 text-xs">Sense compromís. Expliqueu-me el que necessiteu i us faré una proposta.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 shrink-0">
            <a href="mailto:fortea.gerard@mail.com"
              class="inline-flex items-center gap-2 text-sm bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 transition-colors duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
              Enviar correu
            </a>
            <a href="tel:+34616271011"
              class="inline-flex items-center gap-2 text-sm border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white px-4 py-2 transition-colors duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              +34 616 27 10 11
            </a>
          </div>
        </div>

      </main>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('theme-toggle')!;
    const moon = document.getElementById('icon-moon')!;
    const sun = document.getElementById('icon-sun')!;

    function syncIcons() {
      const dark = document.documentElement.classList.contains('dark');
      moon.classList.toggle('hidden', dark);
      sun.classList.toggle('hidden', !dark);
    }

    syncIcons();

    toggle.addEventListener('click', () => {
      const dark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', dark ? 'dark' : 'light');
      syncIcons();
    });
  </script>
</BaseLayout>
