---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: 'Desenvolupador senior Full Stack',
    period: '01/2025 – Actualitat',
    company: 'LABSYSTEMS ARQUITECTURA I GESTIO, S.L.',
    location: 'Barcelona',
    current: true,
    tasks: [
      'Retorn a l\'empresa on vaig treballar anys enrere, aquesta vegada assumint un rol més ampli com a analista i programador fullstack.',
      'Participació en projectes web principalment de l\'àmbit turístic, a més d\'altres sectors, cobrint tant el frontend com el backend.',
      'Anàlisi de requeriments, disseny de solucions i desenvolupament d\'aplicacions web a mida.',
    ],
  },
  {
    role: 'Desenvolupador senior Front-end',
    period: '02/2020 – 05/2023',
    company: 'Editorial Oceano',
    location: 'Barcelona',
    current: false,
    tasks: [
      'Anàlisi, desenvolupament i manteniment d\'aplicacions web destinades a la gestió d\'alumnes.',
      'Manteniment de llocs web.',
      'Suport en l\'anàlisi i desenvolupament del backend.',
    ],
  },
  {
    role: 'Programador web senior FullStack',
    period: '09/2017 – 02/2020',
    company: 'LABSYSTEMS ARQUITECTURA I GESTIO, S.L.',
    location: 'Barcelona',
    current: false,
    tasks: [
      'Gestió, anàlisi i desenvolupament de diferents negocis online.',
      'Desenvolupament de software destinat al sector vacacional.',
    ],
  },
  {
    role: 'Desenvolupador d\'aplicacions web',
    period: '09/2013 – 09/2017',
    company: 'GESTION DE INMUEBLES PIMMO, S.L.',
    location: 'Mataró',
    current: false,
    tasks: [
      'Manteniment i desenvolupament de software intern relacionat amb la gestió immobiliària.',
      'Manteniment d\'ordinadors.',
      'Manteniment dels diferents llocs web de l\'empresa.',
      'Referent tecnològic de l\'empresa.',
    ],
  },
  {
    role: 'Desenvolupador web junior',
    period: '01/2008 – 03/2010',
    company: 'SALA ASSESORS INFORMÀTICS',
    location: 'Mataró',
    current: false,
    tasks: [
      'Desenvolupament de pàgines corporatives i del sector educació amb software propi.',
      'Desenvolupament de diversos ecommerces amb EBD.',
      'Formació, manteniment i desenvolupament de funcionalitats per a software de gestió SAGE.',
      'Migració de VB6 a .NET d\'un software TPV destinat a la venda en botiga.',
    ],
  },
];

const education = [
  {
    period: '09/2024 – 06/2025',
    title: 'Tècnic superior en Desenvolupament d\'Aplicacions Web',
    center: 'IOC',
  },
  {
    period: '09/2004 – 06/2007',
    title: 'Tècnic superior en Informàtica de Gestió',
    center: 'Gesem',
  },
];

const skills = ['PHP', 'JavaScript', 'TypeScript', 'Java', 'Vue.js', 'HTML', 'CSS / Tailwind', 'MySQL'];

const languages = [
  { lang: 'Català', level: 'Natiu' },
  { lang: 'Castellà', level: 'Natiu' },
  { lang: 'Anglès', level: 'B1' },
];
---
<BaseLayout
  title="Gerard Fortea Castellsague — CV · Desenvolupador web Fullstack"
  description="Currículum vitae de Gerard Fortea Castellsague, desenvolupador web Fullstack amb més de 15 anys d'experiència en PHP, JavaScript, TypeScript, Vue.js i MySQL."
>
  <div class="min-h-screen py-8 px-4 md:py-14">
    <div class="max-w-5xl mx-auto shadow-2xl">

      <!-- ACCENT LINE -->
      <div class="h-[3px] bg-blue-600"></div>

      <!-- HEADER -->
      <header class="relative bg-slate-900 dark:bg-slate-950 text-white px-8 py-10 md:px-12">

        <!-- Theme toggle -->
        <button id="theme-toggle" aria-label="Canviar tema"
          class="absolute top-5 right-5 p-2 text-slate-500 hover:text-slate-200 transition-colors">
          <!-- Moon — visible in light mode -->
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-5.4-5.4c0-1.81.89-3.42 2.26-4.4A9.14 9.14 0 0 0 12 3z"/>
          </svg>
          <!-- Sun — visible in dark mode -->
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 hidden">
            <path d="M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7zM2 13h2a1 1 0 0 0 0-2H2a1 1 0 0 0 0 2zm18 0h2a1 1 0 0 0 0-2h-2a1 1 0 0 0 0 2zM11 2v2a1 1 0 0 0 2 0V2a1 1 0 0 0-2 0zm0 18v2a1 1 0 0 0 2 0v-2a1 1 0 0 0-2 0zM5.99 4.58a1 1 0 0 0-1.41 1.41l1.06 1.06a1 1 0 0 0 1.41-1.41L5.99 4.58zm12.37 12.37a1 1 0 0 0-1.41 1.41l1.06 1.06a1 1 0 0 0 1.41-1.41l-1.06-1.06zm1.06-10.96a1 1 0 0 0-1.41-1.41l-1.06 1.06a1 1 0 0 0 1.41 1.41l1.06-1.06zM7.05 18.36a1 1 0 0 0-1.41-1.41l-1.06 1.06a1 1 0 0 0 1.41 1.41l1.06-1.06z"/>
          </svg>
        </button>

        <div class="flex flex-col sm:flex-row items-start gap-7">
          <img
            src="https://media.licdn.com/dms/image/v2/D4D03AQGqT-t39MPcGA/profile-displayphoto-shrink_400_400/profile-displayphoto-shrink_400_400/0/1695049957282?e=1733356800&v=beta&t=vJ0P33zO51tNL4Up2is14Z9dI_eRWYThRSXXtCJEsTU"
            alt="Gerard Fortea"
            class="w-[88px] h-[88px] object-cover shrink-0 border border-slate-700"
          />
          <div>
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight">Gerard Fortea Castellsague</h1>
            <p class="mt-1.5 text-blue-400 font-medium text-base">Desenvolupador web Fullstack</p>
            <p class="mt-3 text-slate-400 text-sm leading-relaxed max-w-2xl">
              Programador amb més de 15 anys d'experiència en el desenvolupament web. Em caracteritzo per ser creatiu,
              resolutiu i altament responsable. Mantinc un enfocament constant en l'adquisició de noves habilitats i
              l'aprenentatge de les últimes tecnologies del sector.
            </p>
          </div>
        </div>
      </header>

      <!-- NAV TABS -->
      <nav class="bg-slate-800 dark:bg-slate-900 border-b border-slate-700 dark:border-slate-800 px-6 flex gap-1">
        <a href="/"
          class="px-4 py-3 text-sm font-medium text-white border-b-2 border-blue-500 -mb-px transition-colors">
          CV
        </a>
        <a href="/serveis"
          class="px-4 py-3 text-sm font-medium text-slate-400 border-b-2 border-transparent hover:text-slate-200 transition-colors">
          Serveis
        </a>
      </nav>

      <div class="flex flex-col md:flex-row">

        <!-- SIDEBAR -->
        <aside class="w-full md:w-64 bg-slate-800 dark:bg-slate-900 text-slate-300 px-6 py-8 shrink-0 border-r border-slate-700 dark:border-slate-800">

          <!-- Contact -->
          <section class="mb-8">
            <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500 mb-4">Contacte</h2>
            <ul class="space-y-3 text-sm">
              <li class="flex items-start gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-slate-500 mt-0.5 shrink-0">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
                <span>Maià de Montcal, Girona</span>
              </li>
              <li class="flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-slate-500 shrink-0">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
                <a href="tel:+34616271011" class="hover:text-white transition-colors">+34 616 27 10 11</a>
              </li>
              <li class="flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-slate-500 shrink-0">
                  <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
                <a href="mailto:fortea.gerard@mail.com" class="hover:text-white transition-colors break-all">fortea.gerard@mail.com</a>
              </li>
            </ul>

            <!-- Social -->
            <div class="flex flex-col gap-2 mt-5">
              <a href="https://www.linkedin.com/in/gerard-fortea-a3863741/" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#0288D1]">
                  <path d="M19 0H5C2.239 0 0 2.239 0 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5V5c0-2.761-2.238-5-5-5zM8 19H5V8h3v11zM6.5 6.732c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zM20 19h-3v-5.604c0-3.368-4-3.113-4 0V19h-3V8h3v1.765c1.396-2.586 7-2.777 7 2.476V19z"/>
                </svg>
                LinkedIn
              </a>
              <a href="https://github.com/drarekx" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub
              </a>
            </div>
          </section>

          <!-- Skills -->
          <section class="mb-8">
            <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500 mb-4">Tecnologies</h2>
            <div class="flex flex-wrap gap-1.5">
              {skills.map(skill => (
                <span class="text-xs border border-slate-600 dark:border-slate-700 text-slate-300 px-2 py-0.5">{skill}</span>
              ))}
            </div>
          </section>

          <!-- Languages -->
          <section>
            <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500 mb-4">Idiomes</h2>
            <ul class="space-y-2.5">
              {languages.map(({ lang, level }) => (
                <li class="flex items-center justify-between text-sm">
                  <span class="text-slate-200">{lang}</span>
                  <span class="text-xs text-slate-500">{level}</span>
                </li>
              ))}
            </ul>
          </section>

        </aside>

        <!-- MAIN CONTENT -->
        <div class="flex-1 bg-white dark:bg-slate-900 px-8 py-8 md:px-10">

          <!-- Experience -->
          <section class="mb-10">
            <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400 dark:text-slate-500 mb-6 pb-2 border-b border-slate-200 dark:border-slate-700">Experiència</h2>
            <div class="space-y-7">
              {experience.map(({ role, period, company, location, tasks, current }) => (
                <div class={`pl-3 ${current ? 'border-l-2 border-blue-500' : 'border-l border-slate-200 dark:border-slate-700'}`}>
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
                    <div>
                      <h3 class="font-semibold text-slate-900 dark:text-slate-100 text-sm">{role}</h3>
                      <p class="text-sm text-slate-500 dark:text-slate-400">{company} · {location}</p>
                    </div>
                    <span class="text-xs text-slate-400 dark:text-slate-500 whitespace-nowrap font-mono pt-0.5">{period}</span>
                  </div>
                  <ul class="space-y-1.5">
                    {tasks.map(task => (
                      <li class="text-sm text-slate-600 dark:text-slate-400 flex gap-2 leading-snug">
                        <span class="text-slate-300 dark:text-slate-600 shrink-0 select-none">—</span>
                        <span>{task}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <!-- Education -->
          <section>
            <h2 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400 dark:text-slate-500 mb-6 pb-2 border-b border-slate-200 dark:border-slate-700">Formació</h2>
            <div class="space-y-5">
              {education.map(({ period, title, center }) => (
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
                  <div>
                    <h3 class="font-medium text-slate-800 dark:text-slate-200 text-sm">{title}</h3>
                    <p class="text-xs text-slate-500 dark:text-slate-400">{center}</p>
                  </div>
                  <span class="text-xs text-slate-400 dark:text-slate-500 whitespace-nowrap font-mono">{period}</span>
                </div>
              ))}
            </div>
          </section>

        </div>
      </div>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('theme-toggle')!;
    const moon = document.getElementById('icon-moon')!;
    const sun = document.getElementById('icon-sun')!;

    function syncIcons() {
      const dark = document.documentElement.classList.contains('dark');
      moon.classList.toggle('hidden', dark);
      sun.classList.toggle('hidden', !dark);
    }

    syncIcons();

    toggle.addEventListener('click', () => {
      const dark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', dark ? 'dark' : 'light');
      syncIcons();
    });
  </script>
</BaseLayout>
