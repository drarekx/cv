---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: 'Desenvolupador senior Full Stack',
    period: '01/2025 – Actualitat',
    company: 'LABSYSTEMS ARQUITECTURA I GESTIO, S.L.',
    location: 'Barcelona',
    tasks: [
      'Retorn a l\'empresa on vaig treballar anys enrere, aquesta vegada assumint un rol més ampli com a analista i programador fullstack.',
      'Participació en projectes web principalment de l\'àmbit turístic, a més d\'altres sectors, cobrint tant el frontend com el backend.',
      'Anàlisi de requeriments, disseny de solucions i desenvolupament d\'aplicacions web a mida.',
    ],
  },
  {
    role: 'Desenvolupador senior Front-end',
    period: '02/2020 – 05/2023',
    company: 'Editorial Oceano',
    location: 'Barcelona',
    tasks: [
      'Anàlisi, desenvolupament i manteniment d\'aplicacions web destinades a la gestió d\'alumnes.',
      'Manteniment de llocs web.',
      'Suport en l\'anàlisi i desenvolupament del backend.',
    ],
  },
  {
    role: 'Programador web senior FullStack',
    period: '09/2017 – 02/2020',
    company: 'LABSYSTEMS ARQUITECTURA I GESTIO, S.L.',
    location: 'Barcelona',
    tasks: [
      'Gestió, anàlisi i desenvolupament de diferents negocis online.',
      'Desenvolupament de software destinat al sector vacacional.',
    ],
  },
  {
    role: 'Desenvolupador d\'aplicacions web',
    period: '09/2013 – 09/2017',
    company: 'GESTION DE INMUEBLES PIMMO, S.L.',
    location: 'Mataró',
    tasks: [
      'Manteniment i desenvolupament de software intern relacionat amb la gestió immobiliària.',
      'Manteniment d\'ordinadors.',
      'Manteniment dels diferents llocs web de l\'empresa.',
      'Referent tecnològic de l\'empresa.',
    ],
  },
  {
    role: 'Desenvolupador web junior',
    period: '01/2008 – 03/2010',
    company: 'SALA ASSESORS INFORMÀTICS',
    location: 'Mataró',
    tasks: [
      'Desenvolupament de pàgines corporatives i del sector educació amb software propi.',
      'Desenvolupament de diversos ecommerces amb EBD.',
      'Formació, manteniment i desenvolupament de funcionalitats per a software de gestió SAGE.',
      'Migració de VB6 a .NET d\'un software TPV destinat a la venda en botiga.',
    ],
  },
];

const education = [
  {
    period: '09/2024 – 06/2025',
    title: 'Tècnic superior en Desenvolupament d\'Aplicacions Web',
    center: 'IOC',
  },
  {
    period: '09/2004 – 06/2007',
    title: 'Tècnic superior en Informàtica de Gestió',
    center: 'Gesem',
  },
];

const skills = ['PHP', 'JavaScript', 'TypeScript', 'Java', 'Vue.js', 'HTML', 'CSS / Tailwind', 'MySQL'];

const languages = [
  { lang: 'Català', level: 'Natiu' },
  { lang: 'Castellà', level: 'Natiu' },
  { lang: 'Anglès', level: 'B1' },
];
---
<BaseLayout>
  <main class="min-h-screen py-8 px-4 md:py-12">
    <div class="max-w-5xl mx-auto bg-white shadow-lg rounded-2xl overflow-hidden">

      <!-- TOP HEADER -->
      <div class="bg-slate-800 text-white px-8 py-8 md:px-12 md:py-10">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <img
            src="https://media.licdn.com/dms/image/v2/D4D03AQGqT-t39MPcGA/profile-displayphoto-shrink_400_400/profile-displayphoto-shrink_400_400/0/1695049957282?e=1733356800&v=beta&t=vJ0P33zO51tNL4Up2is14Z9dI_eRWYThRSXXtCJEsTU"
            alt="Gerard Fortea"
            class="w-24 h-24 rounded-full object-cover border-4 border-slate-600 shrink-0"
          />
          <div>
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Gerard Fortea Castellsague</h1>
            <p class="mt-1 text-slate-300 text-lg font-medium">Desenvolupador web Fullstack</p>
            <p class="mt-3 text-slate-400 text-sm leading-relaxed max-w-2xl">
              Programador amb més de 15 anys d'experiència en el desenvolupament web. Em caracteritzo per ser creatiu,
              resolutiu i altament responsable. Mantinc un enfocament constant en l'adquisició de noves habilitats i
              l'aprenentatge de les últimes tecnologies del sector.
            </p>
          </div>
        </div>
      </div>

      <div class="flex flex-col md:flex-row">

        <!-- SIDEBAR -->
        <aside class="w-full md:w-72 bg-slate-50 border-r border-slate-200 px-6 py-8 shrink-0">

          <!-- Contact -->
          <section class="mb-8">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Contacte</h2>
            <ul class="space-y-2 text-sm text-slate-600">
              <li class="flex items-start gap-2">
                <span class="mt-0.5 text-slate-400">📍</span>
                <span>Maià de Montcal, Girona</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-slate-400">📞</span>
                <a href="tel:+34616271011" class="hover:text-slate-800 transition-colors">+34 616 27 10 11</a>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-slate-400">✉️</span>
                <a href="mailto:fortea.gerard@mail.com" class="hover:text-slate-800 transition-colors break-all">fortea.gerard@mail.com</a>
              </li>
            </ul>

            <!-- Social links -->
            <div class="flex gap-3 mt-4">
              <a
                href="https://www.linkedin.com/in/gerard-fortea-a3863741/"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-xs text-white bg-[#0288D1] px-3 py-1.5 rounded-full hover:opacity-90 transition-opacity"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
                LinkedIn
              </a>
              <a
                href="https://github.com/drarekx"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-xs text-white bg-slate-700 px-3 py-1.5 rounded-full hover:opacity-90 transition-opacity"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub
              </a>
            </div>
          </section>

          <!-- Skills -->
          <section class="mb-8">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Tecnologies</h2>
            <div class="flex flex-wrap gap-2">
              {skills.map(skill => (
                <span class="text-xs bg-slate-800 text-white px-2.5 py-1 rounded-full">{skill}</span>
              ))}
            </div>
          </section>

          <!-- Languages -->
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Idiomes</h2>
            <ul class="space-y-2">
              {languages.map(({ lang, level }) => (
                <li class="flex items-center justify-between text-sm">
                  <span class="text-slate-700 font-medium">{lang}</span>
                  <span class="text-xs text-slate-500 bg-slate-200 px-2 py-0.5 rounded-full">{level}</span>
                </li>
              ))}
            </ul>
          </section>

        </aside>

        <!-- MAIN CONTENT -->
        <div class="flex-1 px-6 py-8 md:px-10 md:py-8">

          <!-- Experience -->
          <section class="mb-10">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-5 pb-2 border-b border-slate-200">Experiència</h2>
            <div class="space-y-7">
              {experience.map(({ role, period, company, location, tasks }) => (
                <div>
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
                    <div>
                      <h3 class="font-semibold text-slate-800">{role}</h3>
                      <p class="text-sm text-slate-500">{company} · {location}</p>
                    </div>
                    <span class="text-xs text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full whitespace-nowrap self-start">{period}</span>
                  </div>
                  <ul class="mt-2 space-y-1">
                    {tasks.map(task => (
                      <li class="text-sm text-slate-600 flex gap-2">
                        <span class="text-slate-300 mt-1 shrink-0">›</span>
                        <span>{task}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <!-- Education -->
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-5 pb-2 border-b border-slate-200">Formació</h2>
            <div class="space-y-4">
              {education.map(({ period, title, center }) => (
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
                  <div>
                    <h3 class="font-medium text-slate-800 text-sm">{title}</h3>
                    <p class="text-xs text-slate-500">{center}</p>
                  </div>
                  <span class="text-xs text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full whitespace-nowrap self-start">{period}</span>
                </div>
              ))}
            </div>
          </section>

        </div>
      </div>
    </div>
  </main>
</BaseLayout>
